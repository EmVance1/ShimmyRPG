#
# a = 0
# b = 1
# for i in 0..5 {
#     temp = a + b
#     a = b
#     b = temp
# }

module Default

START = <Narrator: "init"> :: ( fib.i = 0, fib.a = 0, fib.b = 1 ) => loop

loop = if (fib.i < 10) then
    <Narrator: "loop"> :: ( fib.temp = fib.a + fib.b, fib.a = fib.b, fib.b = fib.temp, fib.i += 1 ) => loop
else
    <Narrator: "end">  :: ( OnFibEnd ) => EXIT
end

endmod

